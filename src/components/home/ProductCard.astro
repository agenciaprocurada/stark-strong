---
import Icon from '../core/Icon.astro';
import Card from '../core/Card.astro';
import Button from '../core/Button.astro';
import Pic from '../core/Pic.astro';
import { preferWebp } from '../../lib/img';
import type { ViewProduct } from '../../lib/catalog';

interface Props { product: ViewProduct; }
const { product: p } = Astro.props;
---
<Card variant="default" interactive class="hm-prod" data-cat={p.category}>
  <a class="hm-prod__link" href={`/produto/${p.slug}`} aria-label={`Ver ${p.name}`}></a>
  <div class="hm-prod__imgwrap">
    <Pic class="hm-prod__img" src={p.img} alt={p.name} loading="lazy" />
  </div>
  <div class="hm-prod__body">
    <p class="hm-prod__cat">{p.category}</p>
    <h3 class="hm-prod__name">{p.name}</h3>
    <p class="hm-prod__trust"><Icon name="building-2" size={14} />Stark Strong · linha profissional</p>
    <p class="hm-prod__spec"><Icon name="settings-2" size={15} />{p.spec}</p>
    <div class="hm-prod__actions">
      <Button
        variant="primary"
        size="md"
        icon="plus"
        iconOnly
        title="Adicionar ao orçamento"
        aria-label="Adicionar ao orçamento"
        data-add-orcamento
        data-id={p.id}
        data-name={p.name}
        data-cat={p.category}
        data-img={preferWebp(p.img)}
      >Adicionar ao orçamento</Button>
    </div>
  </div>
</Card>
