---
import Icon from '../core/Icon.astro';
import { getSiteConfig } from '../../lib/catalog';

const cfg = await getSiteConfig();
---
<div class="hm-topbar">
  <div class="hm-topbar__items">
    <span class="hm-topbar__item"><Icon name="truck" size={15} color="var(--accent)" /> Entregamos em <b>todo o Brasil</b></span>
    <span class="hm-topbar__sep"></span>
    <span class="hm-topbar__item">Orçamento <b>sem compromisso</b></span>
    <span class="hm-topbar__sep"></span>
    <span class="hm-topbar__item">Projeto, instalação e <b>suporte próprio</b></span>
  </div>
  <div class="hm-topbar__social">
    {cfg.instagram && <a href={cfg.instagram} target="_blank" rel="noopener" aria-label="Instagram"><Icon name="instagram" size={16} /></a>}
    {cfg.youtube && <a href={cfg.youtube} target="_blank" rel="noopener" aria-label="YouTube"><Icon name="youtube" size={16} /></a>}
    {cfg.whatsappSocial && <a href={cfg.whatsappSocial} target="_blank" rel="noopener" aria-label="WhatsApp"><Icon name="message-circle" size={16} /></a>}
  </div>
</div>
