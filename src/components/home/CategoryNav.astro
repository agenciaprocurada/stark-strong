---
import Icon from '../core/Icon.astro';
import { getCategories, getSiteConfig } from '../../lib/catalog';

const categories = await getCategories();
const cfg = await getSiteConfig();
---
<nav class="hm-cats">
  {categories.map((c) => <a class="hm-cats__link" href={`/produtos#${c.slug}`}>{c.nome}</a>)}
  {cfg.telefone && <span class="hm-cats__phone"><Icon name="headset" size={16} color="var(--accent)" /> Atendimento <b>{cfg.telefone}</b></span>}
</nav>
