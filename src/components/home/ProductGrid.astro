---
import ProductCard from './ProductCard.astro';
import { getProducts, getCategories } from '../../lib/catalog';

const products = await getProducts();
const categories = await getCategories();
const FILTERS = [{ nome: 'Todos', slug: '' }, ...categories.map((c) => ({ nome: c.nome, slug: c.slug }))];
---
<section class="hm-section" id="produtos">
  <div class="hm-sectionhead" data-reveal>
    <div>
      <p class="u-overline">Catálogo completo</p>
      <h2 class="hm-title">LINHA <span>PROFISSIONAL</span></h2>
    </div>
  </div>

  <p class="hm-products__intro" data-reveal>Monte sua lista de equipamentos e solicite um orçamento único — sem preço público, sem compromisso. Adicione quantos quiser; a Stark Strong retorna com proposta e prazo.</p>

  <div class="hm-filter" id="hm-filter" data-reveal>
    {FILTERS.map((f, i) => (
      <button class={`hm-chip${i === 0 ? ' is-active' : ''}`} type="button" data-filter={f.nome} data-slug={f.slug}>{f.nome}</button>
    ))}
  </div>

  <div class="hm-products" id="hm-products" data-reveal-stagger>
    {products.map((p) => <ProductCard product={p} />)}
  </div>
</section>

<script>
  const wrap = document.getElementById('hm-filter');
  const grid = document.getElementById('hm-products');
  if (wrap && grid) {
    const cards = [...grid.querySelectorAll<HTMLElement>('.hm-prod')];
    const apply = (chip: HTMLElement) => {
      wrap.querySelectorAll('.hm-chip').forEach((c) => c.classList.remove('is-active'));
      chip.classList.add('is-active');
      const f = chip.dataset.filter;
      cards.forEach((c) => {
        c.hidden = f !== 'Todos' && c.dataset.cat !== f;
      });
    };
    wrap.addEventListener('click', (e) => {
      const chip = (e.target as HTMLElement).closest<HTMLElement>('[data-filter]');
      if (chip) apply(chip);
    });
    // ativa o filtro vindo da navegação de categorias (ex.: /produtos#cardio)
    const fromHash = () => {
      const slug = decodeURIComponent(location.hash.replace('#', ''));
      if (!slug) return;
      const chip = wrap.querySelector<HTMLElement>(`[data-slug="${CSS.escape(slug)}"]`);
      if (chip) apply(chip);
    };
    fromHash();
    window.addEventListener('hashchange', fromHash);
  }
</script>
