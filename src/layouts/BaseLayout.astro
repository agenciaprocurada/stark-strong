---
/* Stark Strong — layout base da loja. */
import '../styles/global.css';
import '../styles/orcamento.css';
import OrcamentoDrawer from '../components/OrcamentoDrawer.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Stark Strong — Equipamentos de musculação profissional',
  description = 'Equipamentos de musculação profissional. Biomecânica precisa, durabilidade superior e design premium. Monte seu orçamento — sem compromisso.',
} = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/assets/logo-positive.png" />
    {/* Fontes locais — preload das críticas (título display + corpo) para o LCP */}
    <link rel="preload" href="/fonts/league-spartan-900-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      /* Reveal no scroll. Só liga o movimento quando o usuário aceita.
         Sem JS / movimento reduzido / sem IntersectionObserver => tudo visível. */
      (function () {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        document.documentElement.classList.add('reveal-ready');
        function init() {
          var els = document.querySelectorAll('[data-reveal],[data-reveal-stagger]');
          if (!('IntersectionObserver' in window)) {
            els.forEach(function (el) { el.classList.add('is-in'); });
            return;
          }
          /* threshold 0: dispara com qualquer pixel visível. Não usar fração
             do alvo — containers altos (ex.: grade com 186 produtos) nunca
             atingiriam 12% da própria área e ficariam invisíveis. */
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { e.target.classList.add('is-in'); io.unobserve(e.target); }
            });
          }, { threshold: 0, rootMargin: '0px 0px -8% 0px' });
          els.forEach(function (el) { io.observe(el); });
        }
        if (document.readyState !== 'loading') init();
        else document.addEventListener('DOMContentLoaded', init);
      })();
    </script>
    <script is:inline>
      /* Mede a altura real do header e ajusta o offset do menu de categorias
         (sticky). Evita sobreposição/folga ao rolar, em qualquer largura. */
      (function () {
        function setHeaderH() {
          var h = document.querySelector('.hm-header');
          if (h) document.documentElement.style.setProperty('--header-h', Math.round(h.getBoundingClientRect().height) + 'px');
        }
        if (document.readyState !== 'loading') setHeaderH();
        else document.addEventListener('DOMContentLoaded', setHeaderH);
        window.addEventListener('load', setHeaderH);
        window.addEventListener('resize', setHeaderH);
      })();
    </script>
  </head>
  <body>
    <slot />
    <OrcamentoDrawer />
    <script>
      import '../scripts/orcamento.ts';
    </script>
  </body>
</html>
