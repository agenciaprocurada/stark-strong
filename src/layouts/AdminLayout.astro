---
/* Stark Strong — shell do painel /admin.
   Design replicado do template "PROC Manager": sidebar branca, marca magenta,
   área principal clara. Protegido por sessão (client-side): o conteúdo só
   aparece após confirmar o login; sem sessão, vai pro /admin/login. */
import '../styles/admin.css';

interface Props {
  title?: string;
  active?: 'dashboard' | 'orcamentos' | 'banners' | 'produtos' | 'categorias' | 'usuarios' | 'config' | 'conta';
}
const { title = 'Painel', active = 'dashboard' } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/assets/logo-positive.png" />
    <title>{title} · Stark Strong Admin</title>
  </head>
  <body>
    <div class="adm" data-admin-guard>
      <div class="adm-scrim" data-scrim></div>

      <!-- ===================== SIDEBAR ===================== -->
      <aside class="adm-side" id="adm-side" data-side>
        <div class="adm-side__brand">
          <span class="adm-side__logo">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>
          </span>
          <span class="adm-side__brandtxt">
            <span class="adm-side__name">PROC<b> Manager</b></span>
            <span class="adm-side__role">por Agência Procurada</span>
          </span>
        </div>

        <nav class="adm-nav">
          <span class="adm-nav__sec">Workspace</span>

          <a class:list={['adm-nav__item', { 'is-active': active === 'dashboard' }]} href="/admin">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/></svg>
            Dashboard
          </a>

          <a class:list={['adm-nav__item', { 'is-active': active === 'orcamentos' }]} href="/admin/orcamentos" data-nav="orcamentos" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/><path d="M9 14l2 2 4-4"/></svg>
            Orçamentos
            <span class="adm-nav__badge" data-badge-orcamentos>·</span>
          </a>

          <a class:list={['adm-nav__item', { 'is-active': active === 'banners' }]} href="/admin/banners" data-nav="banners" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2.5"/><circle cx="8.5" cy="8.5" r="1.6"/><path d="m21 15-5-5L5 21"/></svg>
            Banners
            <span class="adm-nav__badge" data-badge-banners>·</span>
          </a>

          <a class:list={['adm-nav__item', { 'is-active': active === 'produtos' }]} href="/admin/produtos" data-nav="produtos" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            Produtos
            <span class="adm-nav__badge" data-badge-produtos>·</span>
          </a>

          <a class:list={['adm-nav__item', { 'is-active': active === 'categorias' }]} href="/admin/categorias" data-nav="categorias" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
            Categorias
            <span class="adm-nav__badge" data-badge-categorias>·</span>
          </a>

          <a class:list={['adm-nav__item', { 'is-active': active === 'usuarios' }]} href="/admin/usuarios" data-nav="usuarios" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Usuários
            <span class="adm-nav__badge" data-badge-usuarios>·</span>
          </a>

          <a class:list={['adm-nav__item', { 'is-active': active === 'config' }]} href="/admin/configuracoes" data-nav="config" hidden>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
            Configurações
          </a>
        </nav>

        <a class="adm-side__site" href="/" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><path d="M15 3h6v6"/><path d="M10 14 21 3"/></svg>
          Ver o site
        </a>

        <div class="adm-side__user">
          <a class="adm-side__account" href="/admin/conta" title="Minha conta">
            <span class="adm-side__avatar" data-avatar>··</span>
            <span class="adm-side__uinfo">
              <span class="adm-side__uname" data-email>—</span>
              <span class="adm-side__usub" data-role>Minha conta</span>
            </span>
          </a>
          <button class="adm-side__logout" data-logout title="Sair" aria-label="Sair">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          </button>
        </div>
      </aside>

      <!-- ===================== MAIN ===================== -->
      <div class="adm-main">
        <!-- barra superior só no mobile: abre o menu lateral -->
        <div class="adm-mtopbar">
          <button class="adm-burger" type="button" data-burger aria-label="Abrir menu" aria-expanded="false" aria-controls="adm-side">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          </button>
          <span class="adm-mtopbar__brand">PROC<b> Manager</b></span>
        </div>
        <slot />
      </div>
    </div>

    <script>
      import { requireAuth, getEmail, iniciais, signOut, getMeuPerfil, podeAcessar } from '../lib/adminAuth';
      import { getCounts, getOrcamentosNovos } from '../lib/adminApi';

      (async () => {
        await requireAuth();

        // perfil + permissões: sem perfil/inativo = sem acesso ao painel
        const perfil = await getMeuPerfil().catch(() => null);
        if (!perfil || !perfil.ativo) {
          alert('Sua conta ainda não tem acesso ao painel. Fale com um administrador.');
          signOut();
          return;
        }

        // revela só os menus permitidos
        document.querySelectorAll('[data-nav]').forEach((el) => {
          const key = el.getAttribute('data-nav') as any;
          (el as HTMLElement).hidden = !podeAcessar(perfil, key);
        });

        const email = await getEmail();
        const elEmail = document.querySelector('[data-email]');
        const elAvatar = document.querySelector('[data-avatar]');
        const elRole = document.querySelector('[data-role]');
        if (elEmail) elEmail.textContent = perfil.nome || email || 'Administrador';
        if (elAvatar) elAvatar.textContent = iniciais(perfil.nome || email);
        if (elRole) elRole.textContent = perfil.papel === 'admin' ? 'Administrador' : 'Editor';

        document.querySelectorAll('[data-logout]').forEach((el) =>
          el.addEventListener('click', (e) => { e.preventDefault(); signOut(); })
        );

        // menu mobile
        const side = document.querySelector('[data-side]');
        const scrim = document.querySelector('[data-scrim]');
        const burger = document.querySelector('[data-burger]');
        const setOpen = (open: boolean) => {
          side?.classList.toggle('is-open', open);
          scrim?.classList.toggle('is-open', open);
          burger?.setAttribute('aria-expanded', String(open));
        };
        burger?.addEventListener('click', () => setOpen(!side?.classList.contains('is-open')));
        scrim?.addEventListener('click', () => setOpen(false));
        // fecha o menu ao tocar num link da sidebar
        side?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));

        // badges de contagem na sidebar
        try {
          const c = await getCounts();
          const bp = document.querySelector('[data-badge-produtos]');
          const bc = document.querySelector('[data-badge-categorias]');
          const bb = document.querySelector('[data-badge-banners]');
          if (bp) bp.textContent = String(c.produtos);
          if (bc) bc.textContent = String(c.categorias);
          if (bb) bb.textContent = String(c.banners);
        } catch {}

        // badge de orçamentos novos (só se o usuário enxerga a aba)
        try {
          if (podeAcessar(perfil, 'orcamentos')) {
            const bo = document.querySelector('[data-badge-orcamentos]');
            if (bo) bo.textContent = String(await getOrcamentosNovos());
          }
        } catch {}

        // revela o shell
        document.querySelector('[data-admin-guard]')?.classList.add('is-ready');
      })();
    </script>
  </body>
</html>
