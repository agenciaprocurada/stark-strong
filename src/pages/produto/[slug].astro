---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopBar from '../../components/home/TopBar.astro';
import Header from '../../components/home/Header.astro';
import CategoryNav from '../../components/home/CategoryNav.astro';
import StoreFooter from '../../components/home/StoreFooter.astro';
import ProductCard from '../../components/home/ProductCard.astro';
import Icon from '../../components/core/Icon.astro';
import Button from '../../components/core/Button.astro';
import { getProducts, getRelated, type ViewProduct } from '../../lib/catalog';
import { preferWebp } from '../../lib/img';
import '../../styles/home.css';
import '../../styles/produto.css';

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

interface Props { product: ViewProduct; }
const { product: p } = Astro.props;

const chips = p.chips;
const gallery = p.gallery && p.gallery.length ? p.gallery : [p.img];
const related = await getRelated(p, 3);

const guarantees = [
  ['truck', 'Entrega para todo o Brasil', 'Logística especializada em maquinário'],
  ['drafting-compass', 'Instalação inclusa', 'Equipe própria monta na sua academia'],
  ['shield-check', 'Garantia de 5 anos', 'Na estrutura · suporte técnico próprio'],
] as const;
---
<BaseLayout title={`${p.name} — Stark Strong`} description={p.spec}>
  <TopBar />
  <Header />
  <CategoryNav />

  <main class="pd">
    <!-- Breadcrumb -->
    <nav class="pd-crumbs" aria-label="Você está em">
      <a href="/">Início</a>
      <Icon name="chevron-right" size={14} />
      <a href={`/produtos#${p.categorySlug}`}>{p.category}</a>
      <Icon name="chevron-right" size={14} />
      <span>{p.name}</span>
    </nav>

    <!-- Topo: galeria + informações -->
    <section class="pd-hero">
      <div class="pd-gallery">
        <div class="pd-gallery__main">
          <img id="pd-main" src={preferWebp(gallery[0])} alt={p.name} />
        </div>
        {gallery.length > 1 && (
          <div class="pd-gallery__thumbs" id="pd-thumbs">
            {gallery.map((g, i) => (
              <button class={`pd-thumb${i === 0 ? ' is-active' : ''}`} type="button" data-src={preferWebp(g)} aria-label={`Imagem ${i + 1}`}>
                <img src={preferWebp(g)} alt="" loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </div>

      <div class="pd-info">
        <p class="pd-info__cat"><span class="hm-topbar__sep"></span>{p.category}</p>
        <h1 class="pd-info__title">{p.name}</h1>

        <div class="pd-info__trust">
          {p.ref && <span class="ss-badge ss-badge--gold">Ref. {p.ref}</span>}
          <span class="pd-info__proof"><Icon name="building-2" size={15} color="var(--accent)" />Stark Strong · linha profissional</span>
        </div>

        {chips.length > 0 && (
          <ul class="pd-specchips">
            {chips.map((c) => (
              <li><Icon name="check" size={14} color="var(--accent)" />{c}</li>
            ))}
          </ul>
        )}

        <div class="pd-buy">
          <div class="pd-buy__price">
            <span class="pd-buy__label">Investimento</span>
            <span class="pd-buy__quote">Sob orçamento</span>
            <span class="pd-buy__note">Resposta com proposta e prazo em até 1 dia útil — sem compromisso.</span>
          </div>
          <div class="pd-buy__actions">
            <Button
              variant="primary"
              size="lg"
              icon="plus"
              data-add-orcamento
              data-id={p.id}
              data-name={p.name}
              data-cat={p.category}
              data-img={preferWebp(p.img)}
            >Adicionar ao orçamento</Button>
          </div>
        </div>

        <ul class="pd-guarantees">
          {guarantees.map(([ic, t, s]) => (
            <li>
              <span class="pd-guarantees__ic"><Icon name={ic} size={18} color="var(--accent)" /></span>
              <div><b>{t}</b><span>{s}</span></div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Descrição -->
    {p.description.length > 0 && (
      <section class="pd-section">
        <div class="pd-overview">
          <div class="pd-overview__copy">
            <p class="u-overline">Sobre o equipamento</p>
            <h2 class="hm-title">ENGENHARIA <span>QUE SE SENTE</span></h2>
            {p.description.map((d) => <p class="pd-overview__p">{d}</p>)}
          </div>
        </div>
      </section>
    )}

    <!-- Ficha técnica -->
    {p.specs.length > 0 && (
      <section class="pd-section pd-section--dark">
        <div class="pd-specs">
          <div class="pd-specs__head">
            <p class="u-overline">Ficha técnica</p>
            <h2 class="hm-title">ESPECIFICAÇÕES</h2>
          </div>
          <dl class="pd-specs__table">
            {p.specs.map((s) => (
              <div class="pd-specs__row">
                <dt>{s.label}</dt>
                <dd>{s.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </section>
    )}

    <!-- Relacionados -->
    {related.length > 0 && (
      <section class="pd-section">
        <div class="hm-sectionhead">
          <div>
            <p class="u-overline">Mesma linha</p>
            <h2 class="hm-title">TAMBÉM EM <span>{p.category.toUpperCase()}</span></h2>
          </div>
          <Button as="a" href={`/produtos#${p.categorySlug}`} variant="ghost" icon="arrow-right" iconRight>Ver tudo</Button>
        </div>
        <div class="pd-related">
          {related.map((r) => <ProductCard product={r} />)}
        </div>
      </section>
    )}
  </main>

  <StoreFooter />
</BaseLayout>

<script>
  const thumbs = document.getElementById('pd-thumbs');
  const main = document.getElementById('pd-main') as HTMLImageElement | null;
  if (thumbs && main) {
    thumbs.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-src]');
      if (!btn) return;
      main.src = btn.dataset.src!;
      thumbs.querySelectorAll('.pd-thumb').forEach((t) => t.classList.remove('is-active'));
      btn.classList.add('is-active');
    });
  }
</script>
