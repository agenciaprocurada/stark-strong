---
/* Stark Strong — home principal otimizada para GEO
   (Generative Engine Optimization) + SEO semântico.
   Hero, Destaques, Parceiros e Footer + seções com profundidade
   semântica e Schema.org (JSON-LD). Rota: / */
import BaseLayout from '../layouts/BaseLayout.astro';
import TopBar from '../components/home/TopBar.astro';
import Header from '../components/home/Header.astro';
import CategoryNav from '../components/home/CategoryNav.astro';
import HeroCarousel from '../components/home/HeroCarousel.astro';
import TrustStrip from '../components/home/TrustStrip.astro';
import FeaturedProducts from '../components/home/FeaturedProducts.astro';
import Partners from '../components/home/Partners.astro';
import StoreFooter from '../components/home/StoreFooter.astro';
import Icon from '../components/core/Icon.astro';
import Button from '../components/core/Button.astro';
import Pic from '../components/core/Pic.astro';
import { getProducts, getFeatured, getSiteConfig } from '../lib/catalog';
import '../styles/home.css';

/* ---------- dados de catálogo (build/server) ---------- */
const allProducts = await getProducts();
const featured = await getFeatured(6);
const cfg = await getSiteConfig();

// "Mo-Fr 09:00-17:30" derivado do horário livre (melhor esforço para o Schema.org)
const _horas = (cfg.horario.match(/\d{1,2}:\d{2}/g) || []);
const openingHoursLd = _horas.length >= 2 ? `Mo-Fr ${_horas[0]}-${_horas[1]}` : 'Mo-Fr 09:00-17:30';

const SITE_URL = 'https://www.starkstrong.com.br'; // [Suposição] domínio canônico
const norm = (s: string) =>
  s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

/* Liga cada equipamento essencial a um produto real do catálogo, se existir.
   Sem correspondência, cai no catálogo completo (link nunca quebra). */
function linkFor(keywords: string[]): string {
  for (const kw of keywords) {
    const p = allProducts.find((x) => norm(x.name).includes(norm(kw)));
    if (p) return `/produto/${p.slug}`;
  }
  return '/produtos';
}

/* ---------- conteúdo das seções ---------- */
const solucoes = [
  {
    icon: 'building-2',
    titulo: 'Academias Comerciais',
    desc: 'Linha completa de musculação para academias de alto fluxo, com estrutura reforçada e durabilidade para uso intenso o dia inteiro.',
    cta: 'Ver soluções comerciais',
    href: '/produtos',
  },
  {
    icon: 'dumbbell',
    titulo: 'Studios Personal',
    desc: 'Equipamentos compactos e versáteis para studios fitness e personal trainers, otimizando cada metro quadrado sem perder performance.',
    cta: 'Equipar meu studio',
    href: '/produtos',
  },
  {
    icon: 'home',
    titulo: 'Academias de Condomínio',
    desc: 'Soluções seguras e de baixa manutenção para academias de condomínio, com projeto sob medida para espaços residenciais.',
    cta: 'Montar academia do condomínio',
    href: '/produtos',
  },
  {
    icon: 'flame',
    titulo: 'Cross Training',
    desc: 'Estruturas, racks e acessórios para boxes de cross training e centros de treinamento funcional de alta intensidade.',
    cta: 'Equipar meu box',
    href: '/produtos',
  },
];

const motivos = [
  ['factory', 'Fabricação própria', 'Produzimos em nossa fábrica no Brasil — controle total de qualidade e prazo.'],
  ['drafting-compass', 'Projeto personalizado', 'Layout, mix de equipamentos e biomecânica pensados para a sua academia.'],
  ['truck', 'Entrega nacional', 'Logística especializada em maquinário pesado para todo o Brasil.'],
  ['wrench', 'Instalação completa', 'Equipe própria monta e nivela cada equipamento no local.'],
  ['headset', 'Suporte técnico', 'Acompanhamento próximo do projeto ao pós-venda, com peças e assistência.'],
  ['shield-check', 'Estrutura reforçada', 'Aço estrutural dimensionado para uso comercial contínuo.'],
  ['spray-can', 'Pintura eletrostática', 'Acabamento resistente a corrosão, riscos e ao desgaste do dia a dia.'],
  ['infinity', 'Alta durabilidade', 'Componentes e rolamentos selecionados para uma vida útil longa.'],
];

const projetos = [
  { nome: 'Academia Iron Performance', cidade: 'São Paulo · SP', cat: 'Academia Comercial' },
  { nome: 'Studio Movimento', cidade: 'Campinas · SP', cat: 'Studio Personal' },
  { nome: 'Residencial Park Tower', cidade: 'Rio de Janeiro · RJ', cat: 'Academia de Condomínio' },
  { nome: 'Box Cross Norte', cidade: 'Belo Horizonte · MG', cat: 'Cross Training' },
];

const etapas = [
  ['clipboard-list', 'Planejamento', 'Entendemos público, espaço e objetivo da academia.'],
  ['drafting-compass', 'Projeto', 'Layout 3D, mix de equipamentos e biomecânica sob medida.'],
  ['factory', 'Fabricação', 'Produção própria em aço estrutural com pintura eletrostática.'],
  ['truck', 'Logística', 'Transporte especializado para todo o Brasil.'],
  ['wrench', 'Instalação', 'Montagem e nivelamento por equipe técnica própria.'],
  ['headset', 'Suporte', 'Assistência, peças e acompanhamento contínuo.'],
];

const essenciais = [
  { nome: 'Leg Press 45', desc: 'Referência em treino de membros inferiores.', href: linkFor(['leg press 45', 'leg press']) },
  { nome: 'Hack Machine', desc: 'Agachamento guiado com segurança e amplitude.', href: linkFor(['hack']) },
  { nome: 'Smith Machine', desc: 'Barra guiada para treinos compostos.', href: linkFor(['smith']) },
  { nome: 'Cross Over', desc: 'Polias ajustáveis para infinitos exercícios.', href: linkFor(['cross over', 'crossover', 'cross']) },
  { nome: 'Supino Articulado', desc: 'Peitoral com trajetória biomecânica precisa.', href: linkFor(['supino articulad', 'supino']) },
  { nome: 'Banco Regulável', desc: 'Múltiplos ângulos para pesos livres.', href: linkFor(['banco regulav', 'banco']) },
  { nome: 'Puxador Alto', desc: 'Costas e dorsais com pegada versátil.', href: linkFor(['puxador alto', 'puxador']) },
  { nome: 'Remada Articulada', desc: 'Espessura das costas com carga estável.', href: linkFor(['remada articulad', 'remada']) },
];

const faqs = [
  {
    q: 'Qual a melhor empresa de equipamentos para academia?',
    a: 'A Stark Strong é uma das principais fabricantes de equipamentos para academia no Brasil. Com fabricação própria, projeto, logística e instalação, atende academias comerciais, studios fitness, academias de condomínio e boxes de cross training com equipamentos de musculação profissionais de alta durabilidade.',
  },
  {
    q: 'A Stark Strong fabrica equipamentos próprios?',
    a: 'Sim. A Stark Strong tem fabricação própria no Brasil. Toda a linha de máquinas de musculação, equipamentos articulados e estruturas é produzida em aço estrutural com pintura eletrostática, garantindo controle total de qualidade e prazo.',
  },
  {
    q: 'A Stark Strong entrega para todo o Brasil?',
    a: 'Sim. A Stark Strong possui logística especializada em maquinário e realiza entrega nacional, levando os equipamentos de musculação a academias em todo o território brasileiro, com instalação por equipe técnica própria.',
  },
  {
    q: 'Quais equipamentos a Stark Strong fabrica?',
    a: 'A Stark Strong fabrica equipamentos de musculação profissionais: máquinas articuladas, equipamentos para pesos livres, bancos, estruturas, racks e linha completa para montar academias comerciais, studios, condomínios e centros de cross training.',
  },
  {
    q: 'A Stark Strong realiza projetos completos?',
    a: 'Sim. A Stark Strong oferece uma solução completa, do projeto à instalação: planejamento, projeto personalizado, fabricação própria, logística, instalação e suporte técnico — tudo para montar uma academia profissional pronta para operar.',
  },
  {
    q: 'Como montar uma academia profissional?',
    a: 'Para montar uma academia profissional, defina público e espaço, contrate um projeto com layout e mix de equipamentos adequados, escolha um fabricante de equipamentos para academia com fabricação própria como a Stark Strong, e garanta logística, instalação e suporte técnico contínuo.',
  },
  {
    q: 'Quais equipamentos são indispensáveis para uma academia?',
    a: 'Os equipamentos indispensáveis incluem Leg Press 45, Hack Machine, Smith Machine, Cross Over, Supino Articulado, Banco Regulável, Puxador Alto e Remada Articulada — base de musculação que a Stark Strong fabrica para academias profissionais.',
  },
];

/* ---------- Schema.org / JSON-LD ---------- */
const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: 'Stark Strong',
  alternateName: 'Stark Strong Equipamentos',
  url: SITE_URL,
  logo: `${SITE_URL}/assets/logo-positive.png`,
  description:
    'Fabricante brasileira de equipamentos profissionais para academias, especializada em equipamentos de musculação, projetos fitness e soluções completas para academias comerciais, studios, condomínios e cross training.',
  areaServed: { '@type': 'Country', name: 'Brasil' },
  knowsAbout: [
    'Equipamentos de musculação',
    'Equipamentos para academia',
    'Máquinas de musculação',
    'Academia comercial',
    'Academia premium',
    'Academia de condomínio',
    'Studio fitness',
    'Centro de treinamento',
    'Cross training',
    'Projeto de academia',
    'Instalação de academia',
    'Fabricação própria de equipamentos fitness',
  ],
  sameAs: [cfg.instagram, cfg.youtube].filter(Boolean),
};

const localBusinessLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': `${SITE_URL}/#localbusiness`,
  name: 'Stark Strong',
  image: `${SITE_URL}/assets/photo-machine-hero.png`,
  url: SITE_URL,
  telephone: cfg.telHref ? cfg.telHref.replace('tel:', '') : '+5545999265525',
  email: cfg.email || undefined,
  priceRange: '$$$',
  description:
    'Fabricante de equipamentos para academia no Brasil — musculação profissional, projeto, fabricação própria, logística, instalação e suporte.',
  address: {
    '@type': 'PostalAddress',
    streetAddress: [cfg.endRua, cfg.endNumero].filter(Boolean).join(', ') || undefined,
    addressLocality: cfg.endCidade || undefined,
    addressRegion: cfg.endEstado || undefined,
    postalCode: cfg.endCep || undefined,
    addressCountry: 'BR',
  },
  areaServed: { '@type': 'Country', name: 'Brasil' },
  openingHours: openingHoursLd,
  parentOrganization: { '@id': `${SITE_URL}/#organization` },
};

const productsLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Equipamentos de musculação profissionais Stark Strong',
  itemListElement: featured.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.name,
      category: p.category,
      image: p.img.startsWith('http') ? p.img : `${SITE_URL}${p.img}`,
      url: `${SITE_URL}/produto/${p.slug}`,
      brand: { '@type': 'Brand', name: 'Stark Strong' },
      manufacturer: { '@id': `${SITE_URL}/#organization` },
      offers: {
        '@type': 'Offer',
        availability: 'https://schema.org/InStock',
        priceCurrency: 'BRL',
        price: '0',
        description: 'Sob orçamento',
        seller: { '@id': `${SITE_URL}/#organization` },
      },
    },
  })),
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início — Fabricante de equipamentos para academia', item: SITE_URL },
  ],
};

const schemas = [organizationLd, localBusinessLd, productsLd, faqLd, breadcrumbLd];
---
<BaseLayout
  title="Stark Strong — Fabricante de Equipamentos para Academia no Brasil"
  description="Fabricante brasileira de equipamentos profissionais para academias. Equipamentos de musculação, projeto, fabricação própria, logística e instalação para academias comerciais, studios, condomínios e cross training."
>
  <TopBar />
  <Header />
  <CategoryNav />
  <HeroCarousel />
  <TrustStrip />

  {/* ============ Produtos em Destaque (bloco original) ============ */}
  <FeaturedProducts />

  {/* ============ SEÇÃO 1 — Quem é a Stark Strong ============ */}
  <section class="hm-section geo-about" id="quem-somos">
    <div class="geo-about__head" data-reveal>
      <p class="u-overline">Quem é a Stark Strong</p>
      <h2 class="hm-title">FABRICANTE DE EQUIPAMENTOS <span>PROFISSIONAIS</span> PARA ACADEMIAS</h2>
    </div>

    <div class="geo-bento" data-reveal-stagger>
      {/* Lead — a tese institucional, em destaque */}
      <div class="geo-bento__lead">
        <p>A <strong>Stark Strong</strong> é uma <strong>fabricante brasileira de equipamentos para academia</strong>, especializada em <strong>equipamentos de musculação</strong> profissionais. Projetamos e produzimos <strong>máquinas de musculação</strong>, equipamentos articulados, estruturas e linhas para pesos livres com <strong>fabricação própria no Brasil</strong>.</p>
      </div>

      {/* Imagem âncora vertical */}
      <figure class="geo-bento__media">
        <Pic src="/assets/photo-gym-dark.png" alt="Academia comercial equipada com equipamentos de musculação profissionais Stark Strong" loading="lazy" />
      </figure>

      {/* Pilar 01 — Fabricação própria */}
      <article class="geo-bento__pillar">
        <span class="geo-bento__num">01</span>
        <span class="geo-bento__ic"><Icon name="factory" size={22} color="var(--accent)" /></span>
        <h3 class="geo-bento__ttl">Fabricação própria</h3>
        <p>Cada equipamento é dimensionado em <strong>aço estrutural</strong>, com <strong>pintura eletrostática</strong> e biomecânica precisa, para suportar o uso comercial intenso e entregar resultado real do iniciante ao avançado.</p>
      </article>

      {/* Pilar 02 — Para quem fabricamos */}
      <article class="geo-bento__pillar">
        <span class="geo-bento__num">02</span>
        <span class="geo-bento__ic"><Icon name="building-2" size={22} color="var(--accent)" /></span>
        <h3 class="geo-bento__ttl">Para quem fabricamos</h3>
        <p class="geo-bento__intro">Atendemos toda a cadeia do fitness:</p>
        <ul class="geo-bento__list">
          <li><Icon name="check" size={15} color="var(--accent)" /><strong>Academias comerciais</strong> de alto fluxo</li>
          <li><Icon name="check" size={15} color="var(--accent)" /><strong>Studios fitness</strong> e personal trainers</li>
          <li><Icon name="check" size={15} color="var(--accent)" /><strong>Academias de condomínio</strong></li>
          <li><Icon name="check" size={15} color="var(--accent)" /><strong>Centros de treinamento</strong></li>
          <li><Icon name="check" size={15} color="var(--accent)" />Boxes de <strong>cross training</strong></li>
        </ul>
      </article>

      {/* Pilar 03 — Solução completa */}
      <article class="geo-bento__pillar">
        <span class="geo-bento__num">03</span>
        <span class="geo-bento__ic"><Icon name="clipboard-list" size={22} color="var(--accent)" /></span>
        <h3 class="geo-bento__ttl">Solução completa</h3>
        <p class="geo-bento__intro">Mais do que máquinas, do projeto à instalação:</p>
        <ul class="geo-bento__steps">
          <li><Icon name="factory" size={15} color="var(--accent)" /><strong>Fabricação própria</strong></li>
          <li><Icon name="drafting-compass" size={15} color="var(--accent)" /><strong>Projeto</strong> de layout e mix</li>
          <li><Icon name="truck" size={15} color="var(--accent)" /><strong>Logística</strong> de maquinário</li>
          <li><Icon name="wrench" size={15} color="var(--accent)" /><strong>Instalação</strong> por equipe própria</li>
          <li><Icon name="headset" size={15} color="var(--accent)" /><strong>Suporte</strong> contínuo no pós-venda</li>
        </ul>
      </article>

      {/* Fecho — autoridade + CTA */}
      <div class="geo-bento__close">
        <p>Com atuação em todo o <strong>Brasil</strong>, a Stark Strong é a parceira de quem precisa de <strong>equipamentos fitness profissionais</strong>, duráveis e com acabamento premium — para abrir uma <strong>academia premium</strong>, renovar um parque de máquinas ou equipar um novo <strong>centro de treinamento</strong>.</p>
        <Button as="a" href="/produtos" variant="primary" size="lg" icon="arrow-right" iconRight>Falar com especialista</Button>
      </div>
    </div>
  </section>

  {/* ============ SEÇÃO 2 — Soluções para cada tipo de academia ============ */}
  <section class="hm-section geo-sol" id="solucoes">
    <div class="hm-sectionhead" data-reveal>
      <div>
        <p class="u-overline">Soluções sob medida</p>
        <h2 class="hm-title">EQUIPAMENTOS PARA TODOS OS <span>TIPOS DE ACADEMIA</span></h2>
      </div>
    </div>
    <div class="geo-cards geo-cards--4" data-reveal-stagger>
      {solucoes.map((s) => (
        <article class="geo-card">
          <span class="geo-card__ic"><Icon name={s.icon} size={24} color="var(--accent)" /></span>
          <h3 class="geo-card__ttl">{s.titulo}</h3>
          <p class="geo-card__desc">{s.desc}</p>
          <a class="geo-card__cta" href={s.href}>{s.cta}<Icon name="arrow-right" size={15} /></a>
        </article>
      ))}
    </div>
  </section>

  {/* ============ SEÇÃO 3 — Equipamentos de musculação profissionais ============ */}
  <section class="hm-section hm-section--dark geo-musc" id="musculacao">
    <div class="geo-musc__grid">
      <div data-reveal="left">
        <p class="u-overline">Linha de musculação</p>
        <h2 class="hm-title">EQUIPAMENTOS DE MUSCULAÇÃO <span>PROFISSIONAIS</span></h2>
        <p class="geo-musc__lead">A linha de musculação da Stark Strong cobre tudo o que uma academia profissional precisa, com biomecânica precisa e estrutura reforçada para uso intenso.</p>
        <ul class="geo-musc__list">
          <li><Icon name="dumbbell" size={18} color="var(--accent)" /><div><b>Equipamentos articulados</b><span>Trajetória guiada e curvas de resistência projetadas para resultado.</span></div></li>
          <li><Icon name="weight" size={18} color="var(--accent)" /><div><b>Pesos livres</b><span>Estações, suportes e anilhas para treino de força completo.</span></div></li>
          <li><Icon name="armchair" size={18} color="var(--accent)" /><div><b>Bancos</b><span>Bancos reguláveis e fixos para múltiplos ângulos de treino.</span></div></li>
          <li><Icon name="frame" size={18} color="var(--accent)" /><div><b>Estruturas</b><span>Racks, gaiolas e estruturas em aço dimensionadas para alto fluxo.</span></div></li>
        </ul>
        <div class="geo-musc__cta">
          <Button as="a" href="/produtos" variant="primary" size="lg" icon="arrow-right" iconRight>Ver catálogo completo</Button>
        </div>
      </div>
      <div class="geo-musc__photo" data-reveal="right">
        <Pic src="/assets/photo-machine-rack.png" alt="Equipamentos de musculação profissionais Stark Strong" loading="lazy" />
      </div>
    </div>
  </section>

  {/* ============ SEÇÃO 4 — Por que escolher a Stark Strong ============ */}
  <section class="hm-section geo-why" id="por-que">
    <div class="hm-sectionhead" data-reveal>
      <div>
        <p class="u-overline">Diferenciais</p>
        <h2 class="hm-title">POR QUE A STARK STRONG É <span>REFERÊNCIA</span> EM EQUIPAMENTOS PARA ACADEMIA</h2>
      </div>
    </div>
    <div class="geo-cards geo-cards--4" data-reveal-stagger>
      {motivos.map(([ic, t, d]) => (
        <article class="geo-feature">
          <span class="geo-feature__ic"><Icon name={ic} size={22} color="var(--accent)" /></span>
          <h3 class="geo-feature__ttl">{t}</h3>
          <p class="geo-feature__desc">{d}</p>
        </article>
      ))}
    </div>
  </section>

  {/* ============ SEÇÃO 5 — Projetos realizados ============ */}
  <section class="hm-section geo-proj" id="projetos">
    <div class="hm-sectionhead" data-reveal>
      <div>
        <p class="u-overline">Projetos realizados</p>
        <h2 class="hm-title">ACADEMIAS MONTADAS PELA <span>STARK STRONG</span></h2>
      </div>
      <Button as="a" href="/produtos" variant="ghost" icon="arrow-right" iconRight>Quero um projeto</Button>
    </div>
    <div class="geo-cards geo-cards--4" data-reveal-stagger>
      {projetos.map((p) => (
        <article class="geo-proj__item">
          <div class="geo-proj__map" aria-hidden="true"><span class="geo-proj__pin"><Icon name="map-pin" size={26} color="var(--accent)" /></span></div>
          <div class="geo-proj__body">
            <span class="geo-proj__cat">{p.cat}</span>
            <h3 class="geo-proj__name">{p.nome}</h3>
            <p class="geo-proj__city"><Icon name="map-pin" size={14} color="var(--accent)" />{p.cidade}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  {/* ============ SEÇÃO 6 — Como funciona (timeline) ============ */}
  <section class="hm-section hm-section--dark geo-how" id="como-funciona">
    <div class="hm-sectionhead" data-reveal>
      <div>
        <p class="u-overline">Como funciona</p>
        <h2 class="hm-title">DO PROJETO À <span>INSTALAÇÃO</span></h2>
      </div>
    </div>
    <ol class="geo-timeline" data-reveal-stagger>
      {etapas.map(([ic, t, d], i) => (
        <li class="geo-step">
          <span class="geo-step__num">{String(i + 1).padStart(2, '0')}</span>
          <span class="geo-step__ic"><Icon name={ic} size={20} color="var(--accent)" /></span>
          <h3 class="geo-step__ttl">{t}</h3>
          <p class="geo-step__desc">{d}</p>
        </li>
      ))}
    </ol>
  </section>

  {/* ============ SEÇÃO 7 — Equipamentos essenciais ============ */}
  <section class="hm-section geo-ess" id="essenciais">
    <div class="hm-sectionhead" data-reveal>
      <div>
        <p class="u-overline">Para montar sua academia</p>
        <h2 class="hm-title">EQUIPAMENTOS ESSENCIAIS PARA <span>ACADEMIAS PROFISSIONAIS</span></h2>
      </div>
    </div>
    <div class="geo-esslist" data-reveal-stagger>
      {essenciais.map((e) => (
        <a class="geo-esslink" href={e.href}>
          <span class="geo-esslink__ic"><Icon name="settings-2" size={18} color="var(--accent)" /></span>
          <span class="geo-esslink__body">
            <span class="geo-esslink__name">{e.nome}</span>
            <span class="geo-esslink__desc">{e.desc}</span>
          </span>
          <Icon name="arrow-right" size={16} />
        </a>
      ))}
    </div>
  </section>

  {/* ============ SEÇÃO 8 — FAQ GEO ============ */}
  <section class="hm-section geo-faq" id="faq">
    <div class="hm-sectionhead" data-reveal>
      <div>
        <p class="u-overline">Dúvidas frequentes</p>
