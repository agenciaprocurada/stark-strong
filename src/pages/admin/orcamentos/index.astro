---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Orçamentos" active="orcamentos">
  <div class="adm-page">
    <header class="adm-ph">
      <div>
        <p class="adm-ph__over">CRM</p>
        <h1 class="adm-ph__title">Orçamentos</h1>
        <p class="adm-ph__desc">Pedidos recebidos pelo site. Arraste os cards entre as colunas para mudar o status.</p>
      </div>
    </header>

    <div class="adm-toolbar">
      <div class="adm-search">
        <input class="adm-input" type="search" placeholder="Buscar por e-mail, nome ou academia…" data-search />
      </div>
    </div>

    <div class="adm-msg adm-msg--err" data-err hidden></div>
    <div class="adm-msg adm-msg--ok" data-ok hidden></div>

    <div data-board>
      <div class="adm-loading">Carregando orçamentos…</div>
    </div>
  </div>

  <script>
    import { guardAccess } from '../../../lib/adminAuth';
    import { listOrcamentos, moverStatus, type OrcamentoRow, type OrcamentoStatus } from '../../../lib/adminApi';

    const COLS: { key: OrcamentoStatus; label: string }[] = [
      { key: 'novo', label: 'Novos' },
      { key: 'encaminhado', label: 'Encaminhados' },
      { key: 'enviado', label: 'Enviados' },
    ];

    const boardEl = document.querySelector('[data-board]') as HTMLElement;
    const errEl = document.querySelector('[data-err]') as HTMLElement;
    const okEl = document.querySelector('[data-ok]') as HTMLElement;
    const searchEl = document.querySelector('[data-search]') as HTMLInputElement;

    let todos: OrcamentoRow[] = [];
    let busca = '';

    function esc(s: string) { return (s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!)); }
    function showErr(m: string) { errEl.textContent = m; errEl.hidden = false; okEl.hidden = true; setTimeout(() => (errEl.hidden = true), 4000); }
    function showOk(m: string) { okEl.textContent = m; okEl.hidden = false; errEl.hidden = true; setTimeout(() => (okEl.hidden = true), 2200); }

    function dataBR(iso: string) {
      try { return new Date(iso).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' }); } catch { return ''; }
    }

    function filtrar(): OrcamentoRow[] {
      const q = busca.trim().toLowerCase();
      if (!q) return todos;
      return todos.filter((o) =>
        [o.email, o.nome, o.academia].filter(Boolean).some((v) => (v as string).toLowerCase().includes(q)),
      );
    }

    function card(o: OrcamentoRow) {
      const sub = [o.nome, o.academia].filter(Boolean).map((s) => esc(s as string)).join(' · ');
      return `
        <article class="oc-card" data-id="${o.id}" data-status="${o.status}" tabindex="0" role="button" aria-label="Abrir orçamento de ${esc(o.email)}">
          <span class="oc-card__grip" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i></span>
          <p class="oc-card__email">${esc(o.email)}</p>
          ${sub ? `<p class="oc-card__sub">${sub}</p>` : ''}
          <div class="oc-card__meta">
            <span class="oc-card__items">${o.itens_count} ${o.itens_count === 1 ? 'item' : 'itens'}</span>
            <span class="oc-card__date">${dataBR(o.created_at)}</span>
          </div>
        </article>`;
    }

    function render() {
      const lista = filtrar();
      const cols = COLS.map((c) => {
        const itens = lista.filter((o) => o.status === c.key);
        const cards = itens.length
          ? itens.map(card).join('')
          : `<div class="oc-col__empty">Arraste um card para cá</div>`;
        return `
          <section class="oc-col oc-col--${c.key}" data-col="${c.key}">
            <header class="oc-col__head">
              <span class="oc-col__name"><span class="oc-col__dot"></span>${c.label}</span>
              <span class="oc-col__count">${itens.length}</span>
            </header>
            <div class="oc-col__body" data-drop="${c.key}">${cards}</div>
          </section>`;
      }).join('');
      boardEl.innerHTML = `<div class="oc-board">${cols}</div>`;
    }

    async function mover(id: number, status: OrcamentoStatus) {
      const o = todos.find((x) => x.id === id);
      if (!o || o.status === status) return;
      const antigo = o.status;
      o.status = status; // otimista
      render();
      try {
        await moverStatus(id, status);
        showOk('Orçamento movido para "' + COLS.find((c) => c.key === status)!.label + '".');
      } catch (ex) {
        o.status = antigo; render();
        showErr(ex instanceof Error ? ex.message : 'Falha ao mover.');
      }
    }

    /* ---------- drag-and-drop (pointer events: mouse + toque) ---------- */
    type Drag = {
      id: number; status: string; card: HTMLElement; ghost: HTMLElement | null;
      startX: number; startY: number; offX: number; offY: number; moved: boolean; over: HTMLElement | null;
    };
    let drag: Drag | null = null;
    const THRESH = 6;

    boardEl.addEventListener('pointerdown', (e) => {
      if (e.button !== 0) return;
      const card = (e.target as HTMLElement).closest('.oc-card') as HTMLElement | null;
      if (!card) return;
      drag = {
        id: Number(card.dataset.id), status: card.dataset.status!, card,
        ghost: null, startX: e.clientX, startY: e.clientY, offX: 0, offY: 0, moved: false, over: null,
      };
    });

    window.addEventListener('pointermove', (e) => {
      if (!drag) return;
      if (!drag.moved && Math.hypot(e.clientX - drag.startX, e.clientY - drag.startY) < THRESH) return;
      if (!drag.moved) {
        drag.moved = true;
        const r = drag.card.getBoundingClientRect();
        drag.offX = drag.startX - r.left;
        drag.offY = drag.startY - r.top;
        const g = drag.card.cloneNode(true) as HTMLElement;
        g.classList.add('is-ghost');
        g.style.width = r.width + 'px';
        document.body.appendChild(g);
        drag.ghost = g;
        drag.card.classList.add('is-dragging');
        document.body.classList.add('oc-dragging');
      }
      const g = drag.ghost!;
      g.style.transform = `translate(${e.clientX - drag.offX}px, ${e.clientY - drag.offY}px) rotate(1.5deg)`;
      g.style.display = 'none';
      const under = document.elementFromPoint(e.clientX, e.clientY) as HTMLElement | null;
      g.style.display = '';
      const zone = under?.closest('[data-drop]') as HTMLElement | null;
      if (drag.over !== zone) {
        boardEl.querySelectorAll('[data-drop].is-over').forEach((z) => z.classList.remove('is-over'));
        if (zone && zone.dataset.drop !== drag.status) zone.classList.add('is-over');
        drag.over = zone;
      }
    }, { passive: true });

    function endDrag(commit: boolean) {
      if (!drag) return;
      const d = drag; drag = null;
      boardEl.querySelectorAll('[data-drop].is-over').forEach((z) => z.classList.remove('is-over'));
      document.body.classList.remove('oc-dragging');
      if (d.ghost) d.ghost.remove();
      d.card.classList.remove('is-dragging');
      if (!d.moved) {
        location.href = `/admin/orcamentos/ver?id=${d.id}`;   // clique → abre
        return;
      }
      if (commit && d.over && d.over.dataset.drop !== d.status) {
        mover(d.id, d.over.dataset.drop as OrcamentoStatus);
      }
    }
    window.addEventListener('pointerup', () => endDrag(true));
    window.addEventListener('pointercancel', () => endDrag(false));

    // teclado: Enter/Espaço abre o card
    boardEl.addEventListener('keydown', (e) => {
      const card = (e.target as HTMLElement).closest('.oc-card') as HTMLElement | null;
      if (card && (e.key === 'Enter' || e.key === ' ')) {
        e.preventDefault();
        location.href = `/admin/orcamentos/ver?id=${card.dataset.id}`;
      }
    });

    searchEl.addEventListener('input', () => { busca = searchEl.value; render(); });

    (async () => {
      await guardAccess('orcamentos');
      try {
        todos = await listOrcamentos();
        if (!todos.length) {
          boardEl.innerHTML = `<div class="adm-table"><div class="adm-empty"><div class="adm-empty__t">Nenhum orçamento ainda</div>Os pedidos enviados pelo site aparecem aqui.</div></div>`;
          return;
        }
        render();
      } catch (ex) {
        boardEl.innerHTML = '';
        showErr(ex instanceof Error ? ex.message : 'Falha ao carregar orçamentos.');
      }
    })();
  </script>

  <style is:global>
    /* board injetado via innerHTML → estilos globais (scoped não pega em DOM por JS) */
    .oc-board { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; align-items: start; }
    .oc-col { background: var(--bg-soft); border: 1px solid var(--line); border-radius: 14px; padding: 12px 12px 14px; }
    .oc-col__head { display: flex; align-items: center; justify-content: space-between; padding: 6px 6px 14px; }
    .oc-col__name { display: inline-flex; align-items: center; gap: 8px; font-weight: 700; font-size: 12px;
      letter-spacing: .04em; color: var(--ink); text-transform: uppercase; }
    .oc-col__dot { width: 8px; height: 8px; border-radius: 999px; background: var(--col-accent, var(--muted-3)); flex: none; }
    .oc-col__count { background: var(--surface); border: 1px solid var(--line); border-radius: 999px; min-width: 24px; height: 22px;
      display: inline-flex; align-items: center; justify-content: center; padding: 0 8px; font-size: 12px; font-weight: 700; color: var(--muted); }
    .oc-col__body { display: flex; flex-direction: column; gap: 10px; min-height: 72px; border-radius: 10px;
      padding: 4px; margin: -4px; transition: background .15s, box-shadow .15s; }
    .oc-col__body.is-over { background: var(--brand-soft); box-shadow: inset 0 0 0 2px var(--brand-border); }
    .oc-col__empty { text-align: center; color: var(--muted-3); font-size: 12px; padding: 22px 8px;
      border: 1px dashed var(--line-input); border-radius: 10px; }
    /* acentos semânticos por coluna */
    .oc-col--novo { --col-accent: var(--brand); }
    .oc-col--encaminhado { --col-accent: #c98a2b; }
    .oc-col--enviado { --col-accent: #3f9d5b; }

    .oc-card { position: relative; background: var(--surface); border: 1px solid var(--line); border-radius: 11px;
      padding: 13px 14px 13px 26px; box-shadow: var(--shadow-card); cursor: grab; user-select: none; touch-action: pan-y;
      transition: box-shadow .14s, border-color .14s, transform .04s; }
    .oc-card:hover { box-shadow: 0 4px 14px rgba(20,20,40,.10); border-color: var(--line-input); }
    .oc-card:active { cursor: grabbing; }
    .oc-card:focus-visible { outline: 2px solid var(--brand); outline-offset: 2px; }
    .oc-card.is-dragging { opacity: .35; }
    .oc-card.is-ghost { position: fixed; top: 0; left: 0; z-index: 1000; margin: 0; pointer-events: none;
      box-shadow: 0 18px 40px rgba(20,20,40,.28); cursor: grabbing; transform: rotate(1.5deg); }
    /* grip (alça de arraste) */
    .oc-card__grip { position: absolute; left: 9px; top: 14px; display: grid; grid-template-columns: repeat(2, 3px);
      gap: 3px; opacity: .35; transition: opacity .14s; }
    .oc-card:hover .oc-card__grip { opacity: .7; }
    .oc-card__grip i { width: 3px; height: 3px; border-radius: 999px; background: var(--muted-2); }
    .oc-card__email { font-weight: 700; font-size: 13.5px; color: var(--ink); margin: 0; word-break: break-word; line-height: 1.3; }
    .oc-card__sub { font-size: 12px; color: var(--muted); margin: 4px 0 0; }
    .oc-card__meta { display: flex; align-items: center; justify-content: space-between; margin-top: 11px; }
    .oc-card__items { font-size: 11px; font-weight: 700; color: var(--brand-deep); background: var(--brand-tint);
      border-radius: 999px; padding: 3px 9px; }
    .oc-card__date { font-size: 11.5px; color: var(--muted-3); font-variant-numeric: tabular-nums; }

    body.oc-dragging { cursor: grabbing; }
    body.oc-dragging * { cursor: grabbing !important; }

    @media (max-width: 760px) {
      .oc-board { grid-template-columns: 1fr; }
    }
    @media (prefers-reduced-motion: reduce) {
      .oc-card, .oc-col__body { transition: none; }
      .oc-card.is-ghost { transform: none; }
    }
  </style>
</AdminLayout>
