---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="Orçamento" active="orcamentos">
  <div class="adm-page">
    <div style="display:flex;align-items:center;gap:14px;margin-bottom:20px;flex-wrap:wrap">
      <a class="adm-btn adm-btn--ghost adm-btn--md" href="/admin/orcamentos">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        Orçamentos
      </a>
      <span class="adm-ph__spacer"></span>
      <div class="ov-status" data-status-wrap hidden>
        <label class="adm-label" style="margin:0">Status</label>
        <select class="adm-select" data-status>
          <option value="novo">Novo</option>
          <option value="encaminhado">Encaminhado</option>
          <option value="enviado">Enviado</option>
        </select>
      </div>
      <button class="adm-btn adm-btn--ghost adm-btn--md" type="button" data-del hidden style="color:var(--brand-deep)">Excluir</button>
    </div>

    <div class="adm-msg adm-msg--err" data-err hidden></div>
    <div class="adm-msg adm-msg--ok" data-ok hidden></div>

    <div data-loading class="adm-loading">Carregando orçamento…</div>

    <div class="ov-grid" data-view hidden>
      <!-- coluna principal -->
      <div class="ov-main">
        <div class="adm-card adm-card-pad">
          <h3 class="adm-card-h">Solicitante</h3>
          <div class="ov-fields" data-cliente></div>
        </div>

        <div class="adm-card adm-card-pad">
          <h3 class="adm-card-h">Itens do orçamento</h3>
          <div data-itens></div>
        </div>

        <div class="adm-card adm-card-pad">
          <h3 class="adm-card-h">Notas internas</h3>
          <p class="adm-help" style="margin:-6px 0 12px">Anotações livres sobre este orçamento (só a equipe vê).</p>
          <textarea class="adm-textarea" data-notas rows="5" placeholder="Ex.: cliente pediu desconto à vista, retornar dia 10…"></textarea>
          <div style="margin-top:12px">
            <button class="adm-btn adm-btn--primary adm-btn--md" type="button" data-save-notas>Salvar notas</button>
          </div>
        </div>
      </div>

      <!-- trilha lateral: histórico -->
      <aside class="ov-rail">
        <div class="adm-card adm-card-pad">
          <h3 class="adm-card-h">Histórico de passos</h3>
          <form class="ov-addnote" data-form-evento>
            <input class="adm-input" data-evento-input placeholder="Registrar um passo…" />
            <button class="adm-btn adm-btn--ghost adm-btn--sm" type="submit">Adicionar</button>
          </form>
          <ol class="ov-timeline" data-timeline></ol>
        </div>
      </aside>
    </div>
  </div>

  <script>
    import { guardAccess } from '../../../lib/adminAuth';
    import {
      getOrcamento, moverStatus, salvarNotas, addNota, deleteOrcamento,
      type OrcamentoDetalhe, type OrcamentoStatus, type OrcamentoEvento,
    } from '../../../lib/adminApi';

    const PLACEHOLDER = '/assets/photo-machine-hero.png';
    const params = new URLSearchParams(location.search);
    const id = params.get('id') ? Number(params.get('id')) : null;

    const $ = (s: string) => document.querySelector(s) as HTMLElement;
    const loadingEl = $('[data-loading]');
    const viewEl = $('[data-view]');
    const errEl = $('[data-err]'), okEl = $('[data-ok]');
    const clienteEl = $('[data-cliente]');
    const itensEl = $('[data-itens]');
    const timelineEl = $('[data-timeline]');
    const notasEl = $('[data-notas]') as HTMLTextAreaElement;
    const statusSel = $('[data-status]') as HTMLSelectElement;
    const statusWrap = $('[data-status-wrap]');
    const delBtn = $('[data-del]') as HTMLButtonElement;

    let orc: OrcamentoDetalhe | null = null;

    function esc(s: string) { return (s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!)); }
    function showErr(m: string) { errEl.textContent = m; errEl.hidden = false; okEl.hidden = true; window.scrollTo({ top: 0, behavior: 'smooth' }); }
    function showOk(m: string) { okEl.textContent = m; okEl.hidden = false; errEl.hidden = true; setTimeout(() => (okEl.hidden = true), 2500); }

    function dataHora(iso: string) {
      try { return new Date(iso).toLocaleString('pt-BR', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }); }
      catch { return iso; }
    }

    const EV_ICON: Record<OrcamentoEvento['tipo'], string> = {
      criado: '<path d="M20 6 9 17l-5-5"/>',
      status: '<path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>',
      nota: '<path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/>',
    };

    function linha(label: string, valor: string | null, href?: string) {
      if (!valor) return '';
      const v = href ? `<a href="${href}">${esc(valor)}</a>` : esc(valor);
      return `<div class="ov-field"><span class="ov-field__k">${label}</span><span class="ov-field__v">${v}</span></div>`;
    }

    function renderCliente() {
      if (!orc) return;
      clienteEl.innerHTML =
        linha('E-mail', orc.email, `mailto:${orc.email}`) +
        linha('Nome', orc.nome) +
        linha('Academia', orc.academia) +
        linha('WhatsApp', orc.telefone, orc.telefone ? `https://wa.me/55${orc.telefone.replace(/\D/g, '')}` : undefined) +
        linha('Recebido em', dataHora(orc.created_at)) +
        (orc.observacoes ? `<div class="ov-field ov-field--full"><span class="ov-field__k">Observações</span><span class="ov-field__v">${esc(orc.observacoes)}</span></div>` : '');
    }

    function renderItens() {
      if (!orc) return;
      if (!orc.itens.length) { itensEl.innerHTML = '<p class="adm-help">Sem itens.</p>'; return; }
      const total = orc.itens.reduce((n, i) => n + i.qty, 0);
      itensEl.innerHTML = `
        <div class="ov-itens">
          ${orc.itens.map((i) => `
            <div class="ov-item">
              <img src="${esc(i.img || PLACEHOLDER)}" alt="" onerror="this.src='${PLACEHOLDER}'" />
              <div class="ov-item__main">
                ${i.categoria ? `<span class="ov-item__cat">${esc(i.categoria)}</span>` : ''}
                <span class="ov-item__name">${esc(i.nome)}</span>
              </div>
              <span class="ov-item__qty">${i.qty}×</span>
            </div>`).join('')}
        </div>
        <div class="ov-itens__total">Total de itens <b>${total}</b></div>`;
    }

    function renderTimeline() {
      if (!orc) return;
      const ord = [...orc.eventos].sort((a, b) => (a.created_at < b.created_at ? 1 : -1)); // mais recente no topo
      timelineEl.innerHTML = ord.map((ev) => `
        <li class="ov-tl">
          <span class="ov-tl__dot ov-tl__dot--${ev.tipo}">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">${EV_ICON[ev.tipo]}</svg>
          </span>
          <div class="ov-tl__body">
            <p class="ov-tl__desc">${esc(ev.descricao)}</p>
            <p class="ov-tl__meta">${dataHora(ev.created_at)}${ev.autor ? ` · ${esc(ev.autor)}` : ''}</p>
          </div>
        </li>`).join('');
    }

    statusSel.addEventListener('change', async () => {
      if (!orc) return;
      const novo = statusSel.value as OrcamentoStatus;
      if (novo === orc.status) return;
      statusSel.disabled = true;
      try {
        await moverStatus(orc.id, novo);
        orc.status = novo;
        const nova = await getOrcamento(orc.id);
        orc.eventos = nova.eventos;
        renderTimeline();
        showOk('Status atualizado.');
      } catch (ex) {
        statusSel.value = orc.status;
        showErr(ex instanceof Error ? ex.message : 'Falha ao mudar status.');
      } finally {
        statusSel.disabled = false;
      }
    });

    $('[data-save-notas]').addEventListener('click', async () => {
      if (!orc) return;
      const btn = $('[data-save-notas]') as HTMLButtonElement;
      btn.disabled = true; btn.textContent = 'Salvando…';
      try {
        const upd = await salvarNotas(orc.id, notasEl.value);
        orc.notas = upd.notas;
        showOk('Notas salvas.');
      } catch (ex) {
        showErr(ex instanceof Error ? ex.message : 'Falha ao salvar notas.');
      } finally {
        btn.disabled = false; btn.textContent = 'Salvar notas';
      }
    });

    $('[data-form-evento]').addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!orc) return;
      const input = $('[data-evento-input]') as HTMLInputElement;
      const txt = input.value.trim();
      if (!txt) return;
      try {
        const ev = await addNota(orc.id, txt);
        orc.eventos.push(ev);
        input.value = '';
        renderTimeline();
      } catch (ex) {
        showErr(ex instanceof Error ? ex.message : 'Falha ao registrar passo.');
      }
    });

    delBtn.addEventListener('click', async () => {
      if (!orc) return;
      if (!confirm('Excluir este orçamento? Esta ação não pode ser desfeita.')) return;
      delBtn.disabled = true;
      try {
        await deleteOrcamento(orc.id);
        location.href = '/admin/orcamentos';
      } catch (ex) {
        delBtn.disabled = false;
        showErr(ex instanceof Error ? ex.message : 'Falha ao excluir.');
      }
    });

    (async () => {
      await guardAccess('orcamentos');
      if (!id) { loadingEl.textContent = 'Orçamento não encontrado.'; return; }
      try {
        orc = await getOrcamento(id);
        statusSel.value = orc.status;
        notasEl.value = orc.notas || '';
        renderCliente();
        renderItens();
        renderTimeline();
        loadingEl.hidden = true;
        viewEl.hidden = false;
        statusWrap.hidden = false;
        delBtn.hidden = false;
      } catch (ex) {
        loadingEl.hidden = true;
        showErr(ex instanceof Error ? ex.message : 'Falha ao carregar orçamento.');
      }
    })();
  </script>

  <style is:global>
    /* parte do conteúdo é injetado via innerHTML → global (scoped não pega em DOM por JS) */
    .ov-status { display: flex; align-items: center; gap: 8px; }
    .ov-status .adm-select { min-width: 160px; }

    .ov-grid { display: grid; grid-template-columns: 1fr 340px; gap: 20px; align-items: start; }
    .ov-main { display: flex; flex-direction: column; gap: 18px; }

    .ov-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 22px; }
    .ov-field { display: flex; flex-direction: column; gap: 3px; min-width: 0; }
    .ov-field--full { grid-column: 1 / -1; }
    .ov-field__k { font-size: 10.5px; font-weight: 700; letter-spacing: .5px; text-transform: uppercase; color: var(--muted-2); }
    .ov-field__v { font-size: 14px; color: var(--ink); word-break: break-word; }
    .ov-field__v a { color: var(--brand-deep); text-decoration: none; }
    .ov-field__v a:hover { text-decoration: underline; }

    .ov-itens { display: flex; flex-direction: column; gap: 10px; }
    .ov-item { display: flex; align-items: center; gap: 12px; padding: 8px 0; border-bottom: 1px solid var(--line-row); }
    .ov-item:last-child { border-bottom: 0; }
    .ov-item img { width: 48px; height: 48px; border-radius: 8px; object-fit: cover; background: var(--bg-soft); flex: none; }
    .ov-item__main { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
    .ov-item__cat { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--brand); }
    .ov-item__name { font-size: 14px; font-weight: 600; color: var(--ink); }
    .ov-item__qty { font-family: var(--mono); font-size: 14px; font-weight: 600; color: var(--ink); flex: none; }
    .ov-itens__total { display: flex; justify-content: space-between; margin-top: 12px; padding-top: 12px;
      border-top: 1px solid var(--line); font-size: 13px; font-weight: 600; color: var(--muted); }
    .ov-itens__total b { color: var(--ink); font-family: var(--mono); }

    .ov-addnote { display: flex; gap: 8px; margin-bottom: 16px; }
    .ov-addnote .adm-input { flex: 1; }

    .ov-timeline { list-style: none; margin: 0; padding: 0; position: relative; }
    .ov-tl { display: flex; gap: 12px; padding-bottom: 16px; position: relative; }
    .ov-tl:not(:last-child)::before { content: ""; position: absolute; left: 13px; top: 26px; bottom: 0; width: 2px; background: var(--line); }
    .ov-tl__dot { flex: none; width: 28px; height: 28px; border-radius: 999px; display: grid; place-items: center;
      background: var(--bg-soft); border: 1px solid var(--line); color: var(--muted); z-index: 1; }
    .ov-tl__dot--criado { background: var(--brand-tint); border-color: var(--brand-border); color: var(--brand-deep); }
    .ov-tl__dot--status { background: #eef4ff; border-color: #cfe0ff; color: #2b6cff; }
    .ov-tl__body { padding-top: 3px; min-width: 0; }
    .ov-tl__desc { margin: 0; font-size: 13.5px; color: var(--ink); }
    .ov-tl__meta { margin: 3px 0 0; font-size: 11.5px; color: var(--muted-3); }

    @media (max-width: 880px) {
      .ov-grid { grid-template-columns: 1fr; }
      .ov-fields { grid-template-columns: 1fr; }
    }
  </style>
</AdminLayout>
