---
import '../../styles/admin.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/assets/logo-positive.png" />
    <title>Entrar · Stark Strong Admin</title>
  </head>
  <body>
    <div class="adm-login">
      <!-- ===== Hero ===== -->
      <div class="adm-login__hero">
        <div class="adm-login__wash"></div>
        <span class="adm-login__glow adm-login__glow--1"></span>
        <span class="adm-login__glow adm-login__glow--2"></span>

        <div class="adm-login__lockup">
          <span class="adm-login__lockup-logo">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>
          </span>
          <span>
            <span class="adm-login__lockup-name" style="display:block">PROC Manager</span>
            <span class="adm-login__lockup-sub" style="display:block">por Agência Procurada</span>
          </span>
        </div>

        <div class="adm-login__headline">
          <div class="adm-login__tag"><span></span>Gestão da loja</div>
          <h2 class="adm-login__h2">O catálogo da sua loja, num só lugar.</h2>
          <p class="adm-login__lead">Cadastre produtos, organize categorias e gerencie as imagens com a robustez da marca Stark Strong.</p>
        </div>
      </div>

      <!-- ===== Formulário ===== -->
      <div class="adm-login__pane">
        <form class="adm-login__card" data-form>
          <div class="adm-login__brand">
            <span class="adm-side__logo">
              <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 2 7l10 5 10-5-10-5z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/></svg>
            </span>
            <span>
              <span class="adm-login__brand-name" style="display:block">PROC<b> Manager</b></span>
              <span class="adm-login__brand-sub" style="display:block">por Agência Procurada</span>
            </span>
          </div>

          <h1 class="adm-login__title">Bem-vindo de volta</h1>
          <p class="adm-login__subtitle">Entre na sua conta para gerenciar a loja.</p>

          <div class="adm-msg adm-msg--err" data-err hidden></div>

          <div style="display:flex;flex-direction:column;gap:17px">
            <label style="display:flex;flex-direction:column;gap:7px">
              <span style="font-size:12.5px;font-weight:600;color:var(--ink-3)">E-mail</span>
              <span class="adm-login__inputwrap">
                <svg class="lead" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a6a6ae" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
                <input class="adm-login__field" name="email" type="email" autocomplete="username" required placeholder="voce@starkstrong.com.br" />
              </span>
            </label>

            <label style="display:flex;flex-direction:column;gap:7px">
              <span style="font-size:12.5px;font-weight:600;color:var(--ink-3)">Senha</span>
              <span class="adm-login__inputwrap">
                <svg class="lead" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="#a6a6ae" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <input class="adm-login__field" name="senha" type="password" autocomplete="current-password" required placeholder="Sua senha" data-pw />
                <button type="button" class="adm-login__eye" data-toggle-pw aria-label="Mostrar ou ocultar a senha">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/></svg>
                </button>
              </span>
            </label>

            <button type="submit" class="adm-login__submit" data-submit>
              Entrar
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </button>
          </div>

          <p style="margin:26px 0 0;text-align:center;font-size:13px;color:var(--muted)">
            Sem acesso? <span style="color:var(--brand-deep);font-weight:600">Fale com o administrador</span>
          </p>
        </form>
      </div>
    </div>

    <script>
      import { signIn } from '../../lib/adminAuth';
      import { supabase } from '../../lib/supabase';

      supabase.auth.getSession().then(({ data }) => {
        if (data.session) window.location.replace('/admin');
      });

      const form = document.querySelector('[data-form]') as HTMLFormElement;
      const err = document.querySelector('[data-err]') as HTMLElement;
      const btn = document.querySelector('[data-submit]') as HTMLButtonElement;
      const pw = document.querySelector('[data-pw]') as HTMLInputElement;

      document.querySelector('[data-toggle-pw]')?.addEventListener('click', () => {
        pw.type = pw.type === 'password' ? 'text' : 'password';
      });

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        err.hidden = true;
        btn.disabled = true;
        btn.textContent = 'Entrando…';
        const fd = new FormData(form);
        try {
          await signIn(String(fd.get('email')), String(fd.get('senha')));
          window.location.replace('/admin');
        } catch (ex) {
          err.textContent = ex instanceof Error ? ex.message : 'Falha ao entrar.';
          err.hidden = false;
          btn.disabled = false;
          btn.textContent = 'Entrar';
        }
      });
    </script>
  </body>
</html>
